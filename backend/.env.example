# ── Requerido ─────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=studyai-notes   # crear con dimension=1024, metric=cosine

# ── Notion (opcional) ─────────────────────────────────────────────────────────
# 1. Crear integración en https://www.notion.so/my-integrations
# 2. Compartir una base de datos con la integración
# 3. Copiar el token y el ID de la base de datos
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive (opcional) ───────────────────────────────────────────────────
# 1. Crear cuenta de servicio en Google Cloud Console
# 2. Habilitar Drive API
# 3. Descargar JSON de credenciales
# 4. Compartir la carpeta de Drive con el email de la cuenta de servicio
GOOGLE_SERVICE_ACCOUNT_JSON=/ruta/a/service-account.json
GOOGLE_DRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Obsidian (opcional) ───────────────────────────────────────────────────────
# Ruta a la carpeta raíz del vault de Obsidian
OBSIDIAN_VAULT_PATH=/home/tu-usuario/Documentos/MiVault

# ── Servidor ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOADS_DIR=uploads
DB_PATH=studyai.db
